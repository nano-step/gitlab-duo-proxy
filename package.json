{
  "name": "gitlab-duo-proxy",
  "version": "1.0.0",
  "description": "Proxy server translating Anthropic Messages API to GitLab Duo",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop gitlab-duo-proxy",
    "pm2:restart": "pm2 restart gitlab-duo-proxy",
    "pm2:logs": "pm2 logs gitlab-duo-proxy",
    "pm2:status": "pm2 status gitlab-duo-proxy"
  },
  "dependencies": {
    "gitlab-ai-provider": "^5.0.0",
    "ai": "^6.0.116",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
